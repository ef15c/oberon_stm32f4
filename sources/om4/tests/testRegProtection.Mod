MODULE testRegProtection;
  PROCEDURE^0 p0;
    VAR i: INTEGER;
  END p0;

  PROCEDURE^1 p1;
    VAR i: INTEGER;
  BEGIN i := 1
  END p1;

  PROCEDURE^2 p2;
    VAR i: INTEGER;
  BEGIN i := i + i + 1
  END p2;

  PROCEDURE^3 p3;
    VAR i: INTEGER;
  BEGIN i := (i + 1) + ((i + 2) + (i + 3))
  END p3;

  PROCEDURE^4 p4;
    VAR i: INTEGER;
  BEGIN i := (i + 1) + ((i + 2) + ((i + 3) + (i + 4)))
  END p4;

  PROCEDURE^5 p5;
    VAR i: INTEGER;
  BEGIN i := (i + 1) + ((i + 2) + ((i + 3) + ((i + 4) + (i + 5))))
  END p5;

END testRegProtection.

