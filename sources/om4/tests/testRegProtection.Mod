MODULE testRegProtection;
  IMPORT Kernel;

  TYPE PR = PROCEDURE; PR4 = PROCEDURE^4;

  VAR n: INTEGER;

  PROCEDURE p4*;
    VAR i: INTEGER;
  BEGIN i := (i + 1) + ((i + 2) + ((i + 3) + (i + 4)))
  END p4;

  PROCEDURE p5*;
    VAR i: INTEGER;
  BEGIN i := (i + 1) + ((i + 2) + ((i + 3) + ((i + 4) + (i + 5))))
  END p5;

  PROCEDURE^4 p4s;
    VAR i: INTEGER;
  BEGIN i := (i + 1) + ((i + 2) + ((i + 3) + (i + 4)))
  END p4s;

  PROCEDURE^5 p5s*;
    VAR i: INTEGER;
  BEGIN i := (i + 1) + ((i + 2) + ((i + 3) + ((i + 4) + (i + 5))))
  END p5s;

  PROCEDURE p14*;
    VAR i: INTEGER;
  BEGIN i := (i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i + 1) + ((i + 2) + ((i + 3) + ((i + 4) + (i + 5))))))))))))
  END p14;

  PROCEDURE q14*;
  BEGIN p14
  END q14;

  PROCEDURE r*(p: PR);
  BEGIN p
  END r;

  PROCEDURE^4 r4*(p: PR4);
  BEGIN p
  END r4;

  PROCEDURE* ef*(f: Kernel.ExceptionFrameDesc);
  END ef;

(*
  PROCEDURE ovfl;
    VAR i: INTEGER;
  BEGIN i := (i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i +1) + ((i + 1) + ((i + 2) + ((i + 3) + ((i + 4) + (i + 5)))))))))))))
  END ovfl;
*)

BEGIN n := 1; p4; r(p14); r4(p5s)
END testRegProtection.

