MODULE bugOM4;

  TYPE R = RECORD b1, b2: BYTE; h1, h2, h3: HALFWORD END;

  VAR a: HALFWORD; u: ARRAY 10 OF HALFWORD; r2: R;

  PROCEDURE r*(VAR r1: R);
  BEGIN r1.h2 := -1
  END r;

  PROCEDURE q*(VAR t: ARRAY OF HALFWORD; i: INTEGER);
  BEGIN u[3] := 4; u[i] := a;
    t[3] := 1; t[i] := a
  END q;

  PROCEDURE p*(i: HALFWORD);
  BEGIN
    i := i+10;
    a := a+5;
    i := 20;
    a := 30
  END p;

  PROCEDURE run*;
  BEGIN p(a); q(u, 2); r(r2)
  END run;

END bugOM4.

OM4P.Compile bugOM4.Mod/s~
System.Free bugOM4~
bugOM4.run
OM4Tool.DecObj bugOM4.m4c
decode bugOM4.m4c
