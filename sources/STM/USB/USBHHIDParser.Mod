MODULE USBHHIDParser;  TYPE    ReportItem* = RECORD      offset*, (*byte index in report*)      size*: HALFWORD; (*size of item expressed in number of bits*)      shift*, (*position of item bit in the byte*)      count*: BYTE; (*only for array items*)      sign*: BOOLEAN; (*signed ?*)      logical_min*,  (*min value device can return*)      logical_max*,  (*max value device can return*)      physical_min*, (*min vale read can report*)      physical_max*, (*max value read can report*)      resolution*: INTEGER    END;  (**  * @brief  HID_ReadItem  *         The function read a report item.  * @param  ri: report item  * @param  ndx: report index  * @retval status (0 : fail / otherwise: item value)  *)  PROCEDURE ReadItem*(report: ARRAY OF BYTE; ri: ReportItem; ndx: BYTE): INTEGER;    VAR val, bofs, x: INTEGER;      offset: HALFWORD; shift: BYTE; continue: BOOLEAN;  BEGIN val := 0; continue := TRUE;  offset := ri.offset; shift := ri.shift;    (* get the logical value of the item *)    (* if this is an array, we may need to offset report.*)    IF ri.count > 0 THEN      IF  ri.count <= ndx THEN continue := FALSE (* If app tries to read outside of the array. *)      ELSE bofs := ndx * ri.size + shift; (* calculate bit offset *)        INC(offset, bofs DIV 8); shift := bofs MOD 8 (* calculate byte offset + shift pair from bit offset. *)      END    END;    IF continue THEN (* read data bytes in little endian order *)      IF (ri.size + 7) DIV 8 > 0 THEN val := LSL(report[offset], ((ri.size + 7) DIV 8 - 1)*8) END;      val := LSR(val, shift) MOD LSL(1, ri.size);      IF (val < ri.logical_min) OR (val > ri.logical_max) THEN (* convert logical value to physical value *)        (* See if the number is negative or not. *)        IF ri.sign & ODD(LSR(val, ri.size - 1)) THEN (* yes, so sign extend value to 32 bits. *)          INC(val, LSL(-1, ri.size))        END      END    END    RETURN val*ri.resolution  END ReadItem;END USBHHIDParser.