MODULE CConv; (*convert C initializations in hex strings*)
  IMPORT Display, Fonts, Texts, Oberon, L := SystemLog;

  VAR W: Texts.Writer;

  PROCEDURE base10*;
    VAR S!: Texts.Scanner; comment, count: BYTE;
  BEGIN Texts.OpenScanner(S, Oberon.Par.text, Oberon.Par.pos); Texts.Scan(S);
    comment := 0; count := 0; Texts.Write(W, "$"); Texts.WriteLn(W);
    WHILE (S.class # Texts.Char) OR (S.c # "}") & (S.c # "~") DO
      IF comment = 0 THEN
        IF (S.class = Texts.Char) & (S.c = "/") THEN comment := 1
        ELSIF S.class = Texts.Int THEN Texts.Write(W, " "); Texts.WriteHexVLen(W, S.i, 2, FALSE);
          INC(count); IF count = 16 THEN count := 0; Texts.WriteLn(W) END
        END
      ELSIF comment = 1 THEN
        IF (S.class = Texts.Char) & (S.c = "*") THEN comment := 2 ELSE comment := 0 END
      ELSIF (comment = 2) & (S.class = Texts.Char) & (S.c = "*") THEN comment := 3
      ELSIF comment = 3 THEN
        IF (S.class = Texts.Char) & (S.c = "/") THEN comment := 0 ELSE comment := 2 END
      END;
      Texts.Scan(S)
    END;
    Texts.Write(W, "$"); Texts.WriteLn(W);
    Texts.Append(Oberon.Log, W.buf)
  END base10;

  PROCEDURE char*;
    VAR S!: Texts.Scanner; comment, count, val: BYTE; ch: CHAR;
  BEGIN Texts.OpenScanner(S, Oberon.Par.text, Oberon.Par.pos); Texts.Read(S, ch);
    comment := 0; count := 0; Texts.Write(W, "$"); Texts.WriteLn(W);
    WHILE (ch # "}") & (ch # "~") DO
      IF comment = 0 THEN
        IF ch = "/" THEN comment := 1
        ELSIF ch = "'" THEN Texts.Read(S, ch);
          IF ch = "\" THEN Texts.Read(S, ch);
            IF ch = "0" THEN val := 0
            ELSIF ch = "'" THEN val := ORD(ch)
            ELSIF ch = "b" THEN val := 8
            ELSIF ch = "t" THEN val := 9
            ELSIF ch = "\" THEN val := 5CH
            ELSIF ch = "n" THEN val := 0AH
            ELSE L.DebugChar("ch", ch); Texts.Append(Oberon.Log, W.buf); ASSERT(FALSE)
            END; Texts.Read(S, ch)
          ELSE ASSERT(ch # "'"); val := ORD(ch); Texts.Read(S, ch)
          END; ASSERT(ch = "'");
          Texts.Write(W, " "); Texts.WriteHexVLen(W, val, 2, FALSE);
          INC(count); IF count = 16 THEN count := 0; Texts.WriteLn(W) END
        END
      ELSIF comment = 1 THEN
        IF ch = "*" THEN comment := 2 ELSE comment := 0 END
      ELSIF (comment = 2) & (ch = "*") THEN comment := 3
      ELSIF comment = 3 THEN
        IF ch = "/" THEN comment := 0 ELSE comment := 2 END
      END;
      Texts.Read(S, ch)
    END;
    Texts.Write(W, "$"); Texts.WriteLn(W);
    Texts.Append(Oberon.Log, W.buf)
  END char;

BEGIN Texts.OpenWriter(W); W.col := Display.white; W.fnt := Fonts.This("Mono10.Scn.Fnt")
END CConv.

OM4P.Compile CConv.Mod/s~
System.Free CConv~
